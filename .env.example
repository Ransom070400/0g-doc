# Ask 0G AI widget — docs.0g.ai chat assistant.
# Copy this file to .env.local and fill in the values, then run ./scripts/start-ai.sh
# (or set them in Vercel project settings for production).

# Upstream 0G Compute inference endpoint.
# Obtain via: `0g-compute-cli inference get-secret --provider <PROVIDER_ADDRESS>`
# The CLI prints a service_url — append /v1/proxy here.
# Example: https://example-provider.0g.ai/v1/proxy
ASK_AI_SERVICE_URL=

# Bearer token from the same get-secret command. Starts with app-sk-
ASK_AI_API_KEY=

# Model identifier (see docs/developer-hub/building-on-0g/compute-network/inference.md).
# Examples: GLM-5-FP8, gpt-oss-120b, deepseek-chat-v3-0324, qwen3.6-plus
ASK_AI_MODEL=GLM-5-FP8

# Set to 1 to skip the upstream call and echo a canned reply (useful for local UI testing).
# ASK_AI_MOCK=1

# --- Abuse protection (in-memory; resets on serverless cold starts) ---

# Per-IP throttle: at most N requests per WINDOW seconds (sliding window).
# ASK_AI_RPM_PER_IP=10
# ASK_AI_WINDOW_SECONDS=60

# Hard ceiling on estimated 0G spent across all requests in a UTC day.
# Once exceeded, all callers get 429 until midnight UTC. Leave unset for no cap.
# ASK_AI_DAILY_SPEND_CAP_OG=5

# Token pricing for the configured model in 0G per 1M tokens.
# Defaults match qwen3.6-plus tier-1 pricing (≤256k input).
# ASK_AI_PRICE_IN_PER_1M=0.8
# ASK_AI_PRICE_OUT_PER_1M=4.8

# Comma-separated allowlist of Origin headers permitted to call /api/chat.
# Defaults: docs.0g.ai + localhost:3000/3001 (covers prod + dev).
# If you serve docs from a different host, add it here.
# ASK_AI_ALLOWED_ORIGINS=https://docs.0g.ai,https://staging-docs.0g.ai

# Per-message char cap (anything longer is truncated server-side).
# Stops a single huge message from blowing the daily spend cap.
# ASK_AI_MAX_MESSAGE_CHARS=4000

# pageContext char cap (the markdown of the page the user is reading).
# ASK_AI_MAX_PAGE_CONTEXT_CHARS=8000
