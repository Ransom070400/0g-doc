# Ask 0G AI widget — docs.0g.ai chat assistant.
# Copy this file to .env.local and fill in the values, then run ./scripts/start-ai.sh
# (or set them in Vercel project settings for production).

# Upstream 0G Compute inference endpoint.
# Obtain via: `0g-compute-cli inference get-secret --provider <PROVIDER_ADDRESS>`
# The CLI prints a service_url — append /v1/proxy here.
# Example: https://example-provider.0g.ai/v1/proxy
ASK_AI_SERVICE_URL=

# Bearer token from the same get-secret command. Starts with app-sk-
ASK_AI_API_KEY=

# Model identifier (see docs/developer-hub/building-on-0g/compute-network/inference.md).
# Examples: GLM-5-FP8, gpt-oss-120b, deepseek-chat-v3-0324, qwen3.6-plus
ASK_AI_MODEL=GLM-5-FP8

# Set to 1 to skip the upstream call and echo a canned reply (useful for local UI testing).
# ASK_AI_MOCK=1
